        {
          "name": "Get Current User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/users/me",
