    {
      "name": "Student Management",
      "item": [
        {
          "name": "Create Student (Teacher Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roll_number\": \"2023001\",\n  \"name\": \"Rahul Sharma\",\n  \"email\": \"rahul.sharma@college.com\",\n  \"phone\": \"9876543210\",\n  \"department\": \"Computer Science\",\n  \"semester\": 3,\n  \"gpa\": \"3.8\",\n  \"address\": \"123 Main Street\",\n  \"city\": \"Chennai\",\n  \"state\": \"Tamil Nadu\",\n  \"pincode\": \"600001\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/students",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["students"]
            }
          }
        },
        {
          "name": "Get All Students",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/students?skip=0&limit=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["students"],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
